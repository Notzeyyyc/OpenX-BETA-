# Copy to .env and fill values. Never commit .env.

# WhatsApp admin phone number (no + sign). Example: 628123456789
OPENX_DEV_PHONE_NUMBER=

# OpenRouter API keys (comma-separated). Example:
# OPENX_OPENROUTER_API_KEYS=sk-or-v1-xxxx,sk-or-v1-yyyy
OPENX_OPENROUTER_API_KEYS=

# ADB port: "auto" or explicit port, e.g. 5555
OPENX_ADB_PORT=auto

# Optional plugin controls
OPENX_PLUGINS_NPM=
OPENX_ALLOW_UNPINNED_PLUGINS=false
